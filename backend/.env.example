NETVISION_APP_NAME=NetVision API
NETVISION_APP_VERSION=0.2.0
NETVISION_API_PREFIX=/api/v1
NETVISION_SCAN_LOG_PATH=backend/logs/scans.jsonl
NETVISION_CVE_MAPPING_LOG_PATH=backend/logs/cve_mappings.jsonl
NETVISION_NMAP_BINARY=nmap
NETVISION_DEFAULT_SCAN_TIMEOUT_SECONDS=300
# Optional: NVD API key for CVE lookups (recommended for rate limits)
NETVISION_NVD_API_KEY=
